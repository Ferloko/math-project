# Variables de entorno para producción
NODE_ENV=production
PORT=3001
CORS_ORIGIN=*

# Configuración del servidor
HOST=0.0.0.0

# Rutas de archivos
IMAGES_PATH=../images/
GALLERY_PATH=../galeria.html
DATA_PATH=./data/

# Límites de subida
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp
